{
  "name": "sabertazimi.github.io",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "pnpm lint:style && pnpm lint:type-check",
    "lint:style": "eslint . && stylelint ./src/**/*.css",
    "lint:type-check": "tsc --noEmit",
    "lint:fix": "eslint . --fix && stylelint ./src/**/*.css --fix",
    "changeset": "commit-and-tag-version --dry-run -s",
    "release": "commit-and-tag-version -s"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "^6.2.0",
    "@dg-scripts/stylelint-config": "^6.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.11.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13"
  }
}
